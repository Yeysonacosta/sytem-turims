.header {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  z-index: 9999;
  background: linear-gradient(
    180deg,
    rgba(0, 0, 0, 0.86),
    rgba(0, 0, 0, 0.48),
    transparent
  );
}

.navbar {
  width: 100%;
  min-height: 92px;
  padding: 10px 5%;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.logo {
  display: flex;
  align-items: center;
  flex-shrink: 0;
  transition: transform 0.3s ease;
}

.logo:hover {
  transform: scale(1.06);
}

.logo img {
  width: 70px;
  height: 70px;
  object-fit: contain;
  filter: drop-shadow(0 5px 9px rgba(0, 0, 0, 0.6));
}

.links {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 21px;
}

.link {
  position: relative;
  padding: 11px 0;
  color: #ffffff;
  font-size: 15px;
  font-weight: 750;
  white-space: nowrap;
  text-decoration: none;
  text-shadow: 0 2px 8px rgba(0, 0, 0, 0.9);
  transition: color 0.25s ease, transform 0.25s ease;
}

.link::after {
  content: "";
  position: absolute;
  left: 0;
  bottom: 4px;
  width: 0;
  height: 3px;
  border-radius: 20px;
  background: #32e600;
  transition: width 0.25s ease;
}

.link:hover,
.activo {
  color: #39ef08;
  transform: translateY(-2px);
}

.link:hover::after,
.activo::after {
  width: 100%;
}

.menuButton {
  display: none;
  width: 47px;
  height: 43px;
  padding: 8px;
  border: 1px solid rgba(255, 255, 255, 0.4);
  border-radius: 11px;
  background: rgba(0, 0, 0, 0.5);
  cursor: pointer;
}

.menuButton span {
  display: block;
  width: 100%;
  height: 3px;
  margin: 5px 0;
  border-radius: 20px;
  background: #ffffff;
}

@media (max-width: 1050px) {
  .menuButton {
    display: block;
  }

  .links {
    position: absolute;
    top: 86px;
    left: 18px;
    right: 18px;
    display: none;
    flex-direction: column;
    align-items: stretch;
    gap: 3px;
    padding: 18px;
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 17px;
    background: rgba(7, 20, 18, 0.97);
    backdrop-filter: blur(18px);
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.45);
  }

  .menuAbierto {
    display: flex;
  }

  .link {
    width: 100%;
    padding: 13px 10px;
  }
}